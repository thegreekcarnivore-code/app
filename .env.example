VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Edge-function/server values belong in Supabase project secrets, not in the Vite app env.
# Required server secrets:
# APP_BASE_URL="https://app.thegreekcarnivore.com"
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL_SMALL="gpt-4.1-mini"
# OPENAI_MODEL_STANDARD="gpt-4.1-mini"
# OPENAI_MODEL_PREMIUM="gpt-4.1"
# OPENAI_MODEL_VISION="gpt-4.1"
# OPENAI_MODEL_TRANSCRIPTION="gpt-4o-mini-transcribe"
# RESEND_API_KEY="re_..."
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# ZOOM_ACCOUNT_ID="..."
# ZOOM_CLIENT_ID="..."
# ZOOM_CLIENT_SECRET="..."
# GOOGLE_MAPS_API_KEY="..."
# GOOGLE_SHEETS_SERVICE_KEY="{...json...}"
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
